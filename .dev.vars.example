# Cloudflare Pages Functions のローカル開発用環境変数
# このファイルを .dev.vars にコピーして実際の値を入力すること
# .dev.vars は .gitignore で除外済み

# Notion 統合トークン（読み取り専用、提案ページのみ共有）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 提案データ保存用 Notion ページ ID（URLの末尾32桁）
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 銘柄設定ページの Notion ページ ID（監視銘柄リスト）
NOTION_SETTINGS_PAGE_ID=37a1463a76fd8149a6fbefab8488d844
